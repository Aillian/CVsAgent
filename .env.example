# ---------------------------------------------------------------------------
# CVsAgent – environment configuration
# Copy this file to `.env` and fill in the values you need.
# ---------------------------------------------------------------------------

# Required for OpenAI-backed runs. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Optional: override the default model.
# See https://platform.openai.com/docs/models for available models.
# CVSAGENT_MODEL=gpt-5-mini-2025-08-07

# Optional: use a local LLM via Ollama instead of OpenAI.
# Requires `pip install langchain-ollama` and a running Ollama server.
# CVSAGENT_PROVIDER=ollama
# CVSAGENT_MODEL=llama3.1
# OLLAMA_BASE_URL=http://localhost:11434

# Optional: adjust rate limiting for the OpenAI client (requests per second).
# CVSAGENT_RATE_LIMIT_RPS=0.5

# Optional: default directories (override with CLI flags if needed).
# CVSAGENT_CV_DIR=CVs
# CVSAGENT_OUTPUT_DIR=Output
